{
  "manifest_version": 3,
  "name": "Taffy Overlay for YouTube and Bilibili",
  "description": "Adds a Taffy overlay image to YouTube and Bilibili video thumbnails without replacing the original thumbnails.",
  "version": "1.1.5",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://space.bilibili.com/*"
  ],
  "action": {
    "default_title": "Taffy Overlay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.bilibili.com/*",
        "https://search.bilibili.com/*",
        "https://space.bilibili.com/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/taffy.png",
        "images/assets.json",
        "images/processed/*.png"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://www.bilibili.com/*",
        "https://search.bilibili.com/*",
        "https://space.bilibili.com/*"
      ]
    }
  ]
}
